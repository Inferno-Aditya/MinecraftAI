{
  "BackendDirectory": "../backend",
  "PythonExecutable": "../backend/venv/Scripts/python.exe",
  "HealthEndpoint": "http://127.0.0.1:8000/health",
  "PollIntervalMs": 2000,
  "MaxRestartAttempts": 3,
  "AutoStartBackend": true,
  "AutoStartDashboard": true,
  "DashboardCommand": "npm run dev",
  "DashboardWorkingDirectory": "../dashboard",
  "DashboardHealthUrl": "http://localhost:5173",
  "DashboardRestartAttempts": 3,
  "BackendStartupTimeoutSeconds": 30,
  "DashboardStartupTimeoutSeconds": 30
}
